{
  "name": "crossplayai",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test -c playwright.config.cjs",
    "calibrate:profiles": "node scripts/calibrate-thresholds.mjs",
    "import:corrections": "node scripts/import-corrections.mjs",
    "tune:parser": "node scripts/tune-parser-from-corrections.mjs",
    "benchmark:correction": "node scripts/benchmark-correction.mjs",
    "benchmark:dataset": "node scripts/benchmark-corrections-dataset.mjs",
    "benchmark:dataset:update-baseline": "node scripts/benchmark-corrections-dataset.mjs --update-baseline"
  },
  "dependencies": {
    "@techstark/opencv-js": "^4.11.0-release.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "tesseract.js": "^6.0.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.38.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20.19.9",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^26.1.0",
    "pngjs": "^7.0.0",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^5.4.19",
    "vitest": "^2.1.9"
  }
